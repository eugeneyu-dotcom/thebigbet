{
  "name": "the-big-bet",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node --env-file=.env scripts/sync_expert_csv.mjs && astro dev",
    "build": "node --env-file-if-exists=.env scripts/sync_expert_csv.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "update:matches": "node --env-file-if-exists=.env scripts/update_matches.mjs",
    "update:mlb": "node --env-file-if-exists=.env scripts/update_mlb.mjs",
    "update:standings": "node --env-file-if-exists=.env scripts/update_standings.mjs",
    "update:bracket": "node --env-file-if-exists=.env scripts/update_bracket_results.mjs",
    "update:ai": "node --env-file-if-exists=.env scripts/update_ai_stats.mjs",
    "update:h2h": "node --env-file-if-exists=.env scripts/update_h2h.mjs",
    "update:predictions": "node --env-file-if-exists=.env scripts/update_predictions.mjs",
    "update:all": "npm run update:matches && npm run update:standings && npm run update:bracket && npm run update:ai && npm run update:h2h && npm run update:predictions && node --env-file-if-exists=.env scripts/generate_expert_csv.mjs",
    "push": "node scripts/safe-push.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "chart.js": "^4.5.1",
    "csv-parse": "^7.0.0",
    "csv-stringify": "^6.8.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.3.0"
  }
}
