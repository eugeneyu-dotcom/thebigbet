---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BaseHead from '../../components/BaseHead.astro';
import GoogleAnalytics from '../../components/GoogleAnalytics.astro';
import { languages, useTranslations } from '../../i18n/ui';
import fs from 'fs';
import path from 'path';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const isZhTw = lang === 'zh-tw';
const isTh = lang === 'th';

// MLB odds (moneyline) for the featured section
let mlbMatches: any[] = [];
try {
  const p = path.resolve('src/data/mlbMatches.json');
  if (fs.existsSync(p)) mlbMatches = JSON.parse(fs.readFileSync(p, 'utf8'));
} catch (e) {}
mlbMatches.sort((a, b) => new Date(a.commence_time).getTime() - new Date(b.commence_time).getTime());
const mlbUpcoming = mlbMatches.slice(0, 6);
function moneyline(m: any) {
  const h2h = m.bookmakers?.[0]?.markets?.find((k: any) => k.key === 'h2h');
  const home = h2h?.outcomes?.find((o: any) => o.name === m.home_team)?.price ?? '-';
  const away = h2h?.outcomes?.find((o: any) => o.name === m.away_team)?.price ?? '-';
  return { home, away };
}
const fmtTime = (iso: string) =>
  new Date(iso).toLocaleString(lang === 'zh-tw' ? 'zh-TW' : lang === 'th' ? 'th-TH' : 'en-US', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: false });

// Latest analysis across all sports
const analysisEntries = (await getCollection('analysis', (e) => e.id.startsWith(lang + '/')))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

function articleHref(entry: any) {
  const [, ...slugParts] = entry.id.split('/');
  const slug = slugParts.join('/');
  const league = entry.data.league ?? 'world-cup';
  if (league === 'nba') return `/${lang}/nba/analysis/${slug}`;
  if (league === 'mlb') return `/${lang}/mlb/analysis/${slug}`;
  return `/${lang}/football/world-cup/analysis/${slug}`;
}
const leagueLabel = (league: string) => {
  const l = league ?? 'world-cup';
  if (l === 'nba') return 'NBA';
  if (l === 'mlb') return 'MLB';
  if (l === 'club-football') return t('nav.leagues');
  return t('nav.worldcup');
};

const categories = [
  { href: `/${lang}/football`, label: t('nav.football') },
  { href: `/${lang}/nba`, label: 'NBA' },
  { href: `/${lang}/mlb`, label: 'MLB' },
  { href: `/${lang}/strategy`, label: t('nav.strategy') },
];

const homeDescription = isZhTw
  ? '運動賽事分析與博弈資訊平台：MLB、NBA、足球即時賠率、深度分析與博弈攻略。'
  : isTh
    ? 'แพลตฟอร์มวิเคราะห์กีฬาและข้อมูลเดิมพัน: ราคาสด MLB, NBA, ฟุตบอล พร้อมบทวิเคราะห์เชิงลึกและกลยุทธ์'
    : 'Sports analysis and betting info: live MLB, NBA and football odds, in-depth analysis and betting strategy.';

const oddsHeading = isZhTw ? 'MLB 即時賠率（錢線）' : isTh ? 'ราคา MLB สด (มันนี่ไลน์)' : 'Live MLB Odds (Moneyline)';
const latestHeading = isZhTw ? '最新賽事分析' : isTh ? 'บทวิเคราะห์ล่าสุด' : 'Latest Analysis';
const viewAll = isZhTw ? '看全部' : isTh ? 'ดูทั้งหมด' : 'View all';
---

<html lang={lang}>
  <head>
    <BaseHead title={t('home.title')} description={homeDescription} lang={lang} />
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow w-full">

      <div class="mb-10 text-center">
        <h1 class="text-4xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-yellow-600 tracking-tighter uppercase italic mb-4 drop-shadow-lg">
          THE BIG BET
        </h1>
        <p class="text-slate-400 text-base md:text-lg font-bold max-w-2xl mx-auto">{homeDescription}</p>
      </div>

      <!-- Category quick links -->
      <div class="flex flex-wrap justify-center gap-3 mb-14">
        {categories.map((c) => (
          <a href={c.href} class="px-4 py-2 rounded-full bg-slate-900 border border-slate-800 hover:border-amber-400/50 text-sm font-bold text-slate-200 hover:text-amber-300 transition-colors duration-200">
            {c.label}
          </a>
        ))}
      </div>

      <!-- Featured: MLB odds -->
      <section class="mb-14">
        <div class="flex items-center mb-6">
          <h2 class="text-2xl font-black text-white">{oddsHeading}</h2>
          <a href={`/${lang}/mlb`} class="ml-auto text-sm font-bold text-amber-400 hover:text-amber-300">{viewAll} →</a>
        </div>
        {mlbUpcoming.length === 0 ? (
          <p class="text-slate-500 text-sm">{isZhTw ? '目前暫無 MLB 賠率資料。' : isTh ? 'ยังไม่มีข้อมูลราคา MLB' : 'No MLB odds available right now.'}</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {mlbUpcoming.map((m) => {
              const ml = moneyline(m);
              return (
                <div class="bg-slate-900 border border-slate-800 rounded-xl px-5 py-4">
                  <div class="text-xs text-slate-500 font-mono mb-2">{fmtTime(m.commence_time)}</div>
                  <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
                    <div class="min-w-0"><p class="font-bold text-white truncate">{m.away_team}</p></div>
                    <div class="flex items-center gap-3 font-mono font-black"><span class="text-amber-400">{ml.away}</span><span class="text-slate-600 text-xs">@</span><span class="text-amber-400">{ml.home}</span></div>
                    <div class="min-w-0 text-right"><p class="font-bold text-white truncate">{m.home_team}</p></div>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </section>

      <!-- Latest analysis across sports -->
      <section>
        <h2 class="text-2xl font-black text-white mb-6">{latestHeading}</h2>
        {analysisEntries.length === 0 ? (
          <p class="text-slate-500 text-sm">{isZhTw ? '目前尚無分析文章。' : isTh ? 'ยังไม่มีบทวิเคราะห์' : 'No analysis yet.'}</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {analysisEntries.map((entry) => (
              <a href={articleHref(entry)} class="group block bg-slate-900 border border-slate-800 hover:border-amber-400/40 rounded-2xl p-5 transition-all duration-200">
                <div class="flex items-center gap-2 mb-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-black bg-slate-800 border border-slate-700 text-slate-300 uppercase">{leagueLabel(entry.data.league)}</span>
                  <time class="text-xs text-slate-500 font-mono">{entry.data.pubDate.toLocaleDateString(lang === 'zh-tw' ? 'zh-TW' : lang === 'th' ? 'th-TH' : 'en-US')}</time>
                </div>
                <h3 class="text-base font-bold text-white group-hover:text-amber-300 transition-colors duration-200 line-clamp-2">{entry.data.title}</h3>
                {entry.data.prediction && (
                  <p class="text-sm font-bold text-amber-400 mt-2 truncate">{isZhTw ? '預測：' : isTh ? 'ทำนาย: ' : 'Prediction: '}{entry.data.prediction}</p>
                )}
              </a>
            ))}
          </div>
        )}
      </section>

    </main>
    <Footer />
  </body>
</html>
