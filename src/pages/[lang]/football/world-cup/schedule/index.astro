---
import Header from '../../../../../components/Header.astro';
import Footer from '../../../../../components/Footer.astro';
import BaseHead from '../../../../../components/BaseHead.astro';
import { languages, useTeamTranslations, useTranslations } from '../../../../../i18n/ui';
import standingsData from '../../../../../data/worldCupStandings.json';
import matchesCache from '../../../../../data/matches.json';
import GoogleAnalytics from '../../../../../components/GoogleAnalytics.astro';
import { formatMatchDateTime, getTimeZoneLabel } from '../../../../../utils/timezone';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const tTeam = useTeamTranslations(lang);

const allGroupsFinished = standingsData.every((g: any) => g.teams.every((t: any) => t.mp === 3));

const matches = [...(matchesCache as any[])].sort(
  (a, b) => new Date(a.commence_time).getTime() - new Date(b.commence_time).getTime()
);

// In knockout stage, show all upcoming matches flat (chronological).
// In group stage, group by each team's original group to avoid duplicate entries.
const displaySections: { label: string; matches: any[] }[] = [];

if (allGroupsFinished) {
  // Knockout stage: deduplicate and show all matches chronologically in one list
  const knockoutLabel = lang === 'zh-tw' ? '32強 淘汰賽' : lang === 'th' ? 'รอบ 32 ทีม' : 'Round of 32';
  displaySections.push({ label: knockoutLabel, matches });
} else {
  // Group stage: group matches by their original group, no duplicates
  const allGroupTeams = new Set(standingsData.flatMap((g: any) => g.teams.map((t: any) => t.name)));
  const grouped = standingsData.map((group: any) => {
    const groupMatches = matches.filter(m =>
      group.teams.some((t: any) => t.name === m.home_team) ||
      group.teams.some((t: any) => t.name === m.away_team)
    );
    return { label: group.group, matches: groupMatches };
  }).filter(g => g.matches.length > 0);

  const matchedIds = new Set(grouped.flatMap(g => g.matches.map((m: any) => m.id)));
  const otherMatches = matches.filter(m => !matchedIds.has(m.id));
  displaySections.push(...grouped);
  if (otherMatches.length > 0) {
    displaySections.push({ label: 'Other Matches', matches: otherMatches });
  }
}

const scheduleDescription = lang === 'zh-tw'
  ? '2026 FIFA 世界盃完整賽程表，包含比賽時間、賠率與小組積分，即時更新。'
  : lang === 'th'
    ? 'ตารางฟุตบอลโลก 2026 ฉบับสมบูรณ์ พร้อมเวลาแข่ง อัตราต่อรอง และตารางคะแนน อัปเดตสด'
    : 'Full 2026 FIFA World Cup schedule with match times, live odds, and group standings, updated in real time.';
---

<html lang={lang}>
  <head>
    <BaseHead title={`${t('nav.schedule')} | The Big Bet`} description={scheduleDescription} lang={lang} />
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">

      <div class="mb-12 text-center border-b border-slate-800 pb-8">
        <h1 class="text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-yellow-600 uppercase italic mb-2 tracking-tighter drop-shadow-lg">
          WORLD CUP SCHEDULE
        </h1>
        <p class="text-slate-400 font-bold">{t('nav.schedule')}</p>
        <p class="inline-flex items-center gap-1.5 mt-3 bg-amber-400/10 border border-amber-400/40 text-amber-300 text-sm font-bold px-3 py-1.5 rounded-full">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          {t('schedule.timezoneNote')} {getTimeZoneLabel(lang)}
        </p>
      </div>

      <div class="space-y-16">
        {displaySections.map(section => (
          <section>
            <h2 class="text-xl font-black text-amber-300 mb-6 flex items-center gap-4">
              <span class="bg-slate-900 border border-amber-400/25 px-4 py-2 rounded-lg shadow">{section.label}</span>
              <div class="h-[1px] bg-slate-800 flex-grow"></div>
            </h2>

            <div class="space-y-3">
              {section.matches.map((match: any) => {
                const dateTime = match.commence_time === "TBD" ? "TBD" : formatMatchDateTime(match.commence_time, lang);
                return (
                  <div class="bg-slate-900 border-l-4 border-l-amber-400 p-5 rounded-r-xl shadow flex flex-col md:flex-row md:items-center justify-between hover:bg-slate-800/70 transition-colors duration-200 cursor-default">
                    <div class="text-slate-300 font-mono font-bold text-lg mb-2 md:mb-0 md:w-44">
                      {dateTime}
                    </div>
                    <div class="flex-grow flex items-center justify-center md:justify-start space-x-6">
                      <div class="text-xl font-bold text-white text-right w-1/2 md:w-48">{tTeam(match.home_team)}</div>
                      <div class="text-lg text-amber-300 font-black">VS</div>
                      <div class="text-xl font-bold text-white text-left w-1/2 md:w-48">{tTeam(match.away_team)}</div>
                    </div>
                    <div class="mt-4 md:mt-0 text-center md:text-right">
                      <a href={`/${lang}/`} class="inline-flex items-center gap-1 text-sm font-bold text-amber-400 hover:text-amber-300 uppercase tracking-wider transition-colors duration-200 bg-slate-950 px-4 py-2 rounded-lg border border-slate-700 cursor-pointer">
                        {t('schedule.viewOdds')}
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        ))}
      </div>

    </main>
    <Footer />
  </body>
</html>
