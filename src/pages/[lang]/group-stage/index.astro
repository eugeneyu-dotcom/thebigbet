---
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BaseHead from '../../../components/BaseHead.astro';
import { languages, useTranslations } from '../../../i18n/ui';
import standingsData from '../../../data/worldCupStandings.json';
import GoogleAnalytics from '../../../components/GoogleAnalytics.astro';
import GroupStandingsTable from '../../../components/GroupStandingsTable.astro';
import ThirdPlaceTable from '../../../components/ThirdPlaceTable.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const descriptions: Record<string, string> = {
  'zh-tw': '2026 FIFA 世界盃小組賽完整積分榜，含最佳第三名晉級形勢。',
  'en': '2026 FIFA World Cup full group stage standings, including the best third-placed teams race.',
  'th': 'ตารางคะแนนรอบแบ่งกลุ่มฟุตบอลโลก 2026 ครบทุกกลุ่ม พร้อมสถิติทีมอันดับ 3 ที่ดีที่สุด',
};

const pageTitles: Record<string, string> = {
  'zh-tw': 'GROUP STAGE RESULTS',
  'en': 'GROUP STAGE RESULTS',
  'th': 'GROUP STAGE RESULTS',
};

const pageSubtitles: Record<string, string> = {
  'zh-tw': t('nav.groupStage'),
  'en': t('nav.groupStage'),
  'th': t('nav.groupStage'),
};
---

<html lang={lang}>
  <head>
    <BaseHead title={`${t('nav.groupStage')} | The Big Bet`} description={descriptions[lang] ?? descriptions['en']} lang={lang} />
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">

      <div class="mb-12 text-center border-b border-slate-800 pb-8">
        <h1 class="text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-yellow-600 uppercase italic mb-2 tracking-tighter drop-shadow-lg">
          {pageTitles[lang] ?? pageTitles['en']}
        </h1>
        <p class="text-slate-400 font-bold">{pageSubtitles[lang] ?? pageSubtitles['en']}</p>
      </div>

      <div class="space-y-14">
        <ThirdPlaceTable lang={lang as string} />
        {standingsData.map((groupData: any) => (
          <div>
            <div class="flex items-center mb-6">
              <h2 class="text-2xl font-black text-white">{groupData.group}</h2>
              <div class="h-[2px] bg-gradient-to-r from-amber-400/50 to-transparent flex-grow ml-6"></div>
            </div>
            <GroupStandingsTable groupData={groupData} lang={lang as string} />
          </div>
        ))}
      </div>

    </main>
    <Footer />
  </body>
</html>
