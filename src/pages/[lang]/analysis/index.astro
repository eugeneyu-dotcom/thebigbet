---
import { getCollection } from 'astro:content';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BaseHead from '../../../components/BaseHead.astro';
import { languages, useTranslations, useTeamTranslations } from '../../../i18n/ui';
import GoogleAnalytics from '../../../components/GoogleAnalytics.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const tTeam = useTeamTranslations(lang);
const isZhTw = lang === 'zh-tw';

const allEntries = await getCollection('analysis', (entry) => entry.id.startsWith(lang + '/'));
const sorted = allEntries.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const analysisTitle = isZhTw ? '賽事分析 | The Big Bet' : 'Analysis | The Big Bet';
const analysisDescription = isZhTw
  ? '2026 FIFA 世界盃深度賽事分析文章，包含 AI 評估、賠率解讀與專家預測。'
  : '2026 FIFA World Cup in-depth match analysis with AI assessments, odds breakdowns, and expert predictions.';
---

<html lang={lang}>
  <head>
    <BaseHead title={analysisTitle} description={analysisDescription} lang={lang} />
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">

      <div class="mb-10">
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">
          {isZhTw ? '深度分析' : 'Deep Analysis'}
        </p>
        <h1 class="text-3xl font-black text-white">
          {isZhTw ? '賽事分析文章' : 'Match Analysis'}
        </h1>
        <p class="text-slate-400 mt-2 text-sm leading-relaxed">
          {isZhTw
            ? '由 AI 輔助撰寫的世界盃賽事深度前瞻，整合賠率、歷史交鋒紀錄與戰力分析。'
            : 'AI-assisted World Cup match previews integrating odds, head-to-head records, and team strength analysis.'}
        </p>
      </div>

      {sorted.length === 0 ? (
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-12 text-center">
          <p class="text-slate-500 text-sm">
            {isZhTw ? '目前尚無分析文章，敬請期待。' : 'No analysis articles yet. Check back soon.'}
          </p>
        </div>
      ) : (
        <ul class="space-y-4">
          {sorted.map((entry) => {
            const [entryLang, ...slugParts] = entry.id.split('/');
            const slug = slugParts.join('/');
            const matchParts = entry.data.match.split(' vs ');
            const teamA = tTeam(matchParts[0]?.trim() || '');
            const teamB = tTeam(matchParts[1]?.trim() || '');

            return (
              <li>
                <a
                  href={`/${lang}/analysis/${slug}`}
                  class="group block bg-slate-900 border border-slate-800 hover:border-amber-400/40 rounded-2xl p-6 transition-all duration-200"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-grow min-w-0">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-black bg-amber-400 text-slate-950 uppercase shrink-0">
                          {isZhTw ? `信心 ${entry.data.confidence}/5` : `${entry.data.confidence}/5`}
                        </span>
                        <time class="text-xs text-slate-500 font-mono" datetime={entry.data.pubDate.toISOString()}>
                          {entry.data.pubDate.toLocaleDateString(lang === 'zh-tw' ? 'zh-TW' : 'en-US')}
                        </time>
                      </div>
                      <h2 class="text-lg font-bold text-white group-hover:text-amber-300 transition-colors duration-200 truncate">
                        {entry.data.title}
                      </h2>
                      <p class="text-sm text-slate-400 mt-1">
                        {teamA} <span class="text-slate-600">vs</span> {teamB}
                      </p>
                      {entry.data.prediction && (
                        <p class="text-sm font-bold text-amber-400 mt-2">
                          {isZhTw ? '預測：' : 'Prediction: '}{entry.data.prediction}
                        </p>
                      )}
                    </div>
                    <svg class="w-5 h-5 text-slate-600 group-hover:text-amber-400 shrink-0 mt-1 transition-colors duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </main>
    <Footer />
  </body>
</html>
