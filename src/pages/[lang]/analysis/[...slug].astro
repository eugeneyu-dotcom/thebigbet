---
import '../../../styles/global.css';
import { getCollection, render } from 'astro:content';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { languages } from '../../../i18n/ui';
import GoogleAnalytics from '../../../components/GoogleAnalytics.astro';

export async function getStaticPaths() {
  const analysisEntries = await getCollection('analysis');

  return analysisEntries.map(entry => {
    // entry.id format: "zh-tw/test-match"
    const [lang, ...slugParts] = entry.id.split('/');
    const slug = slugParts.join('/');
    return {
      params: { lang, slug },
      props: { entry },
    };
  });
}

const { lang } = Astro.params;
const { entry } = Astro.props;
const { Content } = await render(entry);

const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <title>{entry.data.title}</title>
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
      <article class="bg-slate-900 rounded-2xl shadow-lg border border-slate-800 p-8">
        <header class="mb-8 border-b border-slate-800 pb-8">
          <div class="flex justify-between items-start mb-4">
            <span class="inline-flex items-center px-3 py-1 rounded text-sm font-black bg-amber-400 text-slate-950 uppercase">
              信心指數: {entry.data.confidence}/5
            </span>
            <time class="text-slate-400 font-mono" datetime={entry.data.pubDate.toISOString()}>
              {entry.data.pubDate.toLocaleDateString()}
            </time>
          </div>
          <h1 class="text-3xl font-bold text-white mb-4">{entry.data.title}</h1>
          <div class="bg-slate-950 p-4 rounded-lg border border-slate-800">
            <p class="font-bold text-slate-300">對戰: <span class="text-white">{entry.data.match}</span></p>
            <p class="font-bold text-slate-300 mt-2">賠率: <span class="text-yellow-400 font-mono">{entry.data.odds}</span></p>
            <p class="font-black text-amber-300 mt-4 text-xl">預測: {entry.data.prediction}</p>
          </div>
        </header>

        <div class="prose prose-invert prose-amber max-w-none prose-img:rounded-xl prose-headings:text-white prose-a:text-amber-400 prose-strong:text-slate-200">
          <Content />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
