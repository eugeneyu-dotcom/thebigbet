---
import '../../../styles/global.css';
import { getCollection, render } from 'astro:content';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PerformanceChart from '../../../components/charts/PerformanceChart.astro';
import H2HChart from '../../../components/charts/H2HChart.astro';
import TeamStatsTable from '../../../components/TeamStatsTable.astro';
import { languages, useTeamTranslations, useTranslations } from '../../../i18n/ui';
import { getDetailedTeamStats, type ScoreData } from '../../../utils/calculateStats';
import GoogleAnalytics from '../../../components/GoogleAnalytics.astro';
import AnalysisAnchor from '../../../components/AnalysisAnchor.astro';
import h2hDatabase from '../../../data/h2hData.json';

export async function getStaticPaths() {
  const analysisEntries = await getCollection('analysis');

  return analysisEntries.map(entry => {
    // entry.id format: "zh-tw/test-match"
    const [lang, ...slugParts] = entry.id.split('/');
    const slug = slugParts.join('/');
    return {
      params: { lang, slug },
      props: { entry },
    };
  });
}

const { lang } = Astro.params;
const { entry } = Astro.props;
const { Content } = await render(entry);
const t = useTranslations(lang);
const tTeam = useTeamTranslations(lang);

// Parse teamA and teamB from "Argentina vs France"
const matchParts = entry.data.match.split(' vs ');
const rawHomeTeam = matchParts[0]?.trim() || '';
const rawAwayTeam = matchParts[1]?.trim() || '';
const homeName = tTeam(rawHomeTeam);
const awayName = tTeam(rawAwayTeam);

import fs from 'fs';
import path from 'path';

// Fetch recent scores to power the dynamic charts automatically from cache
let recentScores: ScoreData[] = [];
try {
  const scoresPath = path.resolve('src/data/scores.json');
  if (fs.existsSync(scoresPath)) {
    recentScores = JSON.parse(fs.readFileSync(scoresPath, 'utf8'));
  }
} catch (e) {
  console.error("Error loading scores.json", e);
}

const detailedHomeStats = getDetailedTeamStats(rawHomeTeam, recentScores);
const detailedAwayStats = getDetailedTeamStats(rawAwayTeam, recentScores);

// Resolve H2H data: prefer auto-fetched DB, fall back to frontmatter
const h2hFromDB = (h2hDatabase as any)[entry.data.match] as number[] | undefined;
const h2hResults: number[] | null =
  (h2hFromDB && h2hFromDB.some(v => v > 0)) ? h2hFromDB :
  (entry.data.h2hData?.some(v => v > 0) ? entry.data.h2hData : null);

const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <title>{entry.data.title} | The Big Bet</title>
    {entry.data.description && <meta name="description" content={entry.data.description} />}
    {entry.data.description && <meta property="og:description" content={entry.data.description} />}
    <meta property="og:title" content={`${entry.data.title} | The Big Bet`} />
    <meta property="og:type" content="article" />
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
      <article class="bg-slate-900 rounded-2xl shadow-lg border border-slate-800 p-8">
        <header class="mb-8">
          <!-- Meta row: label · date · confidence -->
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-6">
            <span class="text-xs font-black text-amber-400 uppercase tracking-widest">賽事深度分析</span>
            <span class="text-slate-700">·</span>
            <time class="text-sm text-slate-400 font-mono" datetime={entry.data.pubDate.toISOString()}>
              {entry.data.pubDate.toLocaleDateString(lang === 'zh-tw' ? 'zh-TW' : 'en-US')}
            </time>
            <span class="ml-auto inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-black bg-amber-400/10 text-amber-300 border border-amber-400/20">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              信心 {entry.data.confidence}/5
            </span>
          </div>

          <!-- Title -->
          <h1 class="text-3xl md:text-4xl font-black text-white leading-tight mb-7">{entry.data.title}</h1>

          <!-- Match info card -->
          <div class="bg-slate-950 rounded-2xl border border-slate-800 p-6">
            <!-- Teams matchup -->
            <div class="flex items-center justify-center gap-6 mb-5">
              <div class="text-center w-[38%]">
                <p class="text-2xl font-black text-white">{homeName}</p>
                <p class="text-xs text-slate-500 uppercase tracking-wide mt-1">主場</p>
              </div>
              <div class="shrink-0 text-center">
                <span class="inline-block text-xs font-black text-slate-400 uppercase tracking-widest bg-slate-800 border border-slate-700 rounded-lg px-3 py-1.5">VS</span>
              </div>
              <div class="text-center w-[38%]">
                <p class="text-2xl font-black text-white">{awayName}</p>
                <p class="text-xs text-slate-500 uppercase tracking-wide mt-1">客場</p>
              </div>
            </div>
            <!-- Odds + prediction -->
            <div class="border-t border-slate-800 pt-4 flex flex-wrap items-end justify-between gap-4">
              <div>
                <p class="text-xs text-slate-500 uppercase tracking-widest font-bold mb-1.5">賠率</p>
                <p class="text-amber-400 font-mono font-bold text-sm">{entry.data.odds}</p>
              </div>
              <div class="text-right">
                <p class="text-xs text-slate-500 uppercase tracking-widest font-bold mb-1.5">本場預測</p>
                <p class="text-xl font-black text-amber-300">{entry.data.prediction}</p>
              </div>
            </div>
          </div>
        </header>

        <div class="article-body prose prose-invert max-w-none prose-img:rounded-xl prose-headings:font-black prose-headings:text-white prose-a:text-amber-400 prose-strong:text-white mb-10 pb-10 border-b border-slate-800">
          <Content components={{ a: AnalysisAnchor }} />
        </div>
        <style>
          .article-body p { color: rgb(203 213 225); line-height: 1.875; }
          .article-body h2 { font-size: 1.2rem; margin-top: 2.5rem; margin-bottom: 0.75rem; padding-left: 1rem; border-left: 4px solid rgb(245 158 11); color: #fff; }
          .article-body li { color: rgb(203 213 225); }
          .article-body a { text-decoration: none; }
        </style>

        <!-- AI Deep Analysis -->
        <section class="mt-8">
          <div class="flex items-center gap-3 mb-6">
            <svg class="w-5 h-5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
            </svg>
            <h2 class="text-xl font-black text-white uppercase tracking-tight">AI Deep Analysis</h2>
            <div class="h-px bg-gradient-to-r from-amber-400/30 to-transparent flex-grow"></div>
          </div>

          <div class="bg-slate-950 p-6 rounded-2xl border border-slate-800">
            {h2hResults && h2hResults.length === 3 && (
              <div class="mb-8">
                <H2HChart teamA={homeName} teamB={awayName} results={h2hResults} />
              </div>
            )}
            
            <PerformanceChart 
              teamA={homeName} 
              teamB={awayName} 
              teamAData={[detailedHomeStats.atk.score, detailedHomeStats.def.score, detailedHomeStats.pos.score, detailedHomeStats.dis.score, detailedHomeStats.frm.score]} 
              teamBData={[detailedAwayStats.atk.score, detailedAwayStats.def.score, detailedAwayStats.pos.score, detailedAwayStats.dis.score, detailedAwayStats.frm.score]} 
            />
            
            <div class="mt-6">
              <TeamStatsTable 
                teamA={homeName} 
                teamB={awayName} 
                teamAStats={detailedHomeStats} 
                teamBStats={detailedAwayStats} 
              />
            </div>
          </div>
        </section>

      </article>
    </main>
    <Footer />
  </body>
</html>
