---
import { render } from 'astro:content';
import Header from './Header.astro';
import Footer from './Footer.astro';
import BaseHead from './BaseHead.astro';
import PerformanceChart from './charts/PerformanceChart.astro';
import H2HChart from './charts/H2HChart.astro';
import TeamStatsTable from './TeamStatsTable.astro';
import { useTeamTranslations, useTranslations } from '../i18n/ui';
import { getDetailedTeamStats, type ScoreData } from '../utils/calculateStats';
import GoogleAnalytics from './GoogleAnalytics.astro';
import AnalysisAnchor from './AnalysisAnchor.astro';
import h2hDatabase from '../data/h2hData.json';
import fs from 'fs';
import path from 'path';

interface Props {
  entry: any;
  lang: string;
}

const { entry, lang } = Astro.props;
const { Content } = await render(entry);
const t = useTranslations(lang as any);
const tTeam = useTeamTranslations(lang as any);

// Which sport drives the layout. Football keeps the radar/H2H charts;
// basketball/baseball use a two-way (no-draw) layout with a simple H2H + form block.
const sport = entry.data.sport ?? 'football';
const isFootball = sport === 'football';
const sportLabel = t(`sport.${sport}` as any);

// Parse teamA and teamB from "Argentina vs France"
const matchParts = entry.data.match.split(' vs ');
const rawHomeTeam = matchParts[0]?.trim() || '';
const rawAwayTeam = matchParts[1]?.trim() || '';
const homeName = tTeam(rawHomeTeam);
const awayName = tTeam(rawAwayTeam);

// Fetch recent scores to power the dynamic charts automatically from cache
let recentScores: ScoreData[] = [];
try {
  const scoresPath = path.resolve('src/data/scores.json');
  if (fs.existsSync(scoresPath)) {
    recentScores = JSON.parse(fs.readFileSync(scoresPath, 'utf8'));
  }
} catch (e) {
  console.error("Error loading scores.json", e);
}

const detailedHomeStats = getDetailedTeamStats(rawHomeTeam, recentScores);
const detailedAwayStats = getDetailedTeamStats(rawAwayTeam, recentScores);

// Resolve H2H data: prefer auto-fetched DB, fall back to frontmatter
const h2hFromDB = (h2hDatabase as any)[entry.data.match] as number[] | undefined;
const h2hResults: number[] | null =
  (h2hFromDB && h2hFromDB.some((v: number) => v > 0)) ? h2hFromDB :
  (entry.data.h2hData?.some((v: number) => v > 0) ? entry.data.h2hData : null);

// Parse odds string. Football is three-way "主勝 X | 平 X | 客勝 X";
// basketball/baseball are two-way "主勝 X | 客勝 X" (no draw column).
const oddsParts = (entry.data.odds || '').split('|').map((s: string) => s.trim());
const homeOddsVal = oddsParts[0]?.match(/[\d.]+/)?.[0] ?? '-';
const drawOddsVal = isFootball ? (oddsParts[1]?.match(/[\d.]+/)?.[0] ?? '-') : null;
const awayOddsVal = (isFootball ? oddsParts[2] : oddsParts[1])?.match(/[\d.]+/)?.[0] ?? '-';

// Two-way H2H/form data for basketball & baseball (from frontmatter).
// h2hData = [homeWins, awayWins]; form arrays use 1 = win, anything else = loss.
const twoWayH2H = (!isFootball && entry.data.h2hData && entry.data.h2hData.length >= 2)
  ? { home: entry.data.h2hData[0], away: entry.data.h2hData[1] }
  : null;
const homeForm = (!isFootball ? entry.data.teamAForm : null) ?? null;
const awayForm = (!isFootball ? entry.data.teamBForm : null) ?? null;
const h2hTotal = twoWayH2H ? twoWayH2H.home + twoWayH2H.away : 0;
const homeWinPct = h2hTotal > 0 ? Math.round((twoWayH2H!.home / h2hTotal) * 100) : 50;
const awayWinPct = 100 - homeWinPct;
const hasTwoWayStats = !!(twoWayH2H || homeForm || awayForm);
---

<html lang={lang}>
  <head>
    <BaseHead
      title={`${entry.data.title} | The Big Bet`}
      description={entry.data.description}
      lang={lang}
      type="article"
    />
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">
      <article class="bg-slate-900 rounded-2xl shadow-lg border border-slate-800 p-8">
        <header class="mb-8">
          <!-- Meta row: label · sport · date · confidence -->
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-6">
            <span class="text-xs font-black text-amber-400 uppercase tracking-widest">{t('analysis.tag')}</span>
            <span class="text-slate-700">·</span>
            <span class="text-xs font-black uppercase tracking-widest px-2 py-0.5 rounded bg-slate-800 border border-slate-700 text-slate-300">{sportLabel}</span>
            <span class="text-slate-700">·</span>
            <time class="text-sm text-slate-400 font-mono" datetime={entry.data.pubDate.toISOString()}>
              {entry.data.pubDate.toLocaleDateString(lang === 'zh-tw' ? 'zh-TW' : lang === 'th' ? 'th-TH' : 'en-US')}
            </time>
            <span class="ml-auto inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-black bg-amber-400/10 text-amber-300 border border-amber-400/20">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              {t('analysis.confidence')} {entry.data.confidence}/5
            </span>
          </div>

          <!-- Title -->
          <h1 class="text-3xl md:text-4xl font-black text-white leading-tight mb-7">{entry.data.title}</h1>

          <!-- Match info card -->
          <div class="bg-slate-950 rounded-2xl border border-slate-800 p-6">
            <div class="grid grid-cols-3 gap-2">
              <div class="text-center">
                <p class="text-2xl font-black text-white leading-tight">{homeName}</p>
                <p class="text-xs text-slate-500 uppercase tracking-wide mt-1">{t('label.home')}</p>
                <div class="mt-4 pt-4 border-t border-slate-800/60">
                  <p class="text-xs text-slate-600 mb-1">{t('odds.home')}</p>
                  <p class="text-2xl font-mono font-black text-amber-400">{homeOddsVal}</p>
                </div>
              </div>
              <div class="text-center flex flex-col items-center justify-center">
                <span class="inline-block text-xs font-black text-slate-400 uppercase tracking-widest bg-slate-800 border border-slate-700 rounded-lg px-3 py-1.5">VS</span>
                {isFootball && (
                  <div class="mt-4 pt-4 border-t border-slate-800/60 w-full">
                    <p class="text-xs text-slate-600 mb-1">{t('odds.draw')}</p>
                    <p class="text-2xl font-mono font-black text-slate-400">{drawOddsVal}</p>
                  </div>
                )}
              </div>
              <div class="text-center">
                <p class="text-2xl font-black text-white leading-tight">{awayName}</p>
                <p class="text-xs text-slate-500 uppercase tracking-wide mt-1">{t('label.away')}</p>
                <div class="mt-4 pt-4 border-t border-slate-800/60">
                  <p class="text-xs text-slate-600 mb-1">{t('odds.away')}</p>
                  <p class="text-2xl font-mono font-black text-amber-400">{awayOddsVal}</p>
                </div>
              </div>
            </div>
            <div class="mt-5 bg-amber-400/5 border border-amber-400/20 rounded-xl px-4 py-3 flex items-center justify-center gap-3">
              <span class="text-xs text-slate-400 font-bold uppercase tracking-widest shrink-0">{t('analysis.prediction')}</span>
              <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              <span class="text-xl font-black text-amber-300">{entry.data.prediction}</span>
            </div>
          </div>
        </header>

        <div class="article-body prose prose-invert max-w-none prose-img:rounded-xl prose-headings:font-black prose-headings:text-white prose-a:text-amber-400 prose-strong:text-white mb-10 pb-10 border-b border-slate-800">
          <Content components={{ a: AnalysisAnchor }} />
        </div>
        <style>
          .article-body p { color: rgb(203 213 225); line-height: 1.875; }
          .article-body h2 { font-size: 1.2rem; margin-top: 2.5rem; margin-bottom: 0.75rem; padding-left: 1rem; border-left: 4px solid rgb(245 158 11); color: #fff; }
          .article-body li { color: rgb(203 213 225); }
          .article-body a { text-decoration: none; }
        </style>

        <!-- Data section: football uses AI radar/H2H charts; other sports use a simple H2H + form block -->
        <section class="mt-8">
          <div class="flex items-center gap-3 mb-6">
            <svg class="w-5 h-5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
            </svg>
            <h2 class="text-xl font-black text-white uppercase tracking-tight">{isFootball ? t('analysis.aiSection') : t('analysis.statsSection')}</h2>
            <div class="h-px bg-gradient-to-r from-amber-400/30 to-transparent flex-grow"></div>
          </div>

          {isFootball ? (
            <div class="bg-slate-950 p-6 rounded-2xl border border-slate-800">
              {h2hResults && h2hResults.length === 3 && (
                <div class="mb-8">
                  <H2HChart teamA={homeName} teamB={awayName} results={h2hResults} lang={lang} />
                </div>
              )}

              <PerformanceChart
                teamA={homeName}
                teamB={awayName}
                teamAData={[detailedHomeStats.atk.score, detailedHomeStats.def.score, detailedHomeStats.pos.score, detailedHomeStats.dis.score, detailedHomeStats.frm.score]}
                teamBData={[detailedAwayStats.atk.score, detailedAwayStats.def.score, detailedAwayStats.pos.score, detailedAwayStats.dis.score, detailedAwayStats.frm.score]}
              />

              <div class="mt-6">
                <TeamStatsTable
                  teamA={homeName}
                  teamB={awayName}
                  teamAStats={detailedHomeStats}
                  teamBStats={detailedAwayStats}
                />
              </div>
            </div>
          ) : (
            <div class="bg-slate-950 p-6 rounded-2xl border border-slate-800">
              {twoWayH2H && (
                <div class="mb-8">
                  <h3 class="text-sm font-black text-slate-300 mb-3">{t('analysis.h2h')}</h3>
                  <div class="flex items-center gap-3">
                    <span class="text-base font-black text-white w-1/4 truncate">{homeName}</span>
                    <div class="flex-1 flex h-6 rounded-full overflow-hidden bg-slate-800 border border-slate-700">
                      <div class="bg-amber-500 h-full" style={`width:${homeWinPct}%`}></div>
                      <div class="bg-sky-500 h-full" style={`width:${awayWinPct}%`}></div>
                    </div>
                    <span class="text-base font-black text-white w-1/4 text-right truncate">{awayName}</span>
                  </div>
                  <div class="flex justify-between mt-2 text-xs font-mono text-slate-400">
                    <span>{twoWayH2H.home} {t('label.win')}</span>
                    <span>{twoWayH2H.away} {t('label.win')}</span>
                  </div>
                </div>
              )}

              {(homeForm || awayForm) && (
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                  {[{ name: homeName, form: homeForm }, { name: awayName, form: awayForm }].map((tm) => tm.form && (
                    <div>
                      <h4 class="text-xs text-slate-500 uppercase tracking-wide mb-2">{tm.name} · {t('analysis.recentForm')}</h4>
                      <div class="flex gap-1.5">
                        {tm.form.map((r: number) => (
                          <span class={`w-7 h-7 rounded flex items-center justify-center text-xs font-black ${r === 1 ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/40' : 'bg-rose-500/20 text-rose-400 border border-rose-500/40'}`}>
                            {r === 1 ? t('label.win') : t('label.loss')}
                          </span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {!hasTwoWayStats && (
                <p class="text-sm text-slate-500 text-center py-4">{t('analysis.noStats')}</p>
              )}
            </div>
          )}
        </section>

      </article>
    </main>
    <Footer />
  </body>
</html>
