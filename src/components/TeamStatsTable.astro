---
import { type DetailedTeamStats } from '../utils/calculateStats';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

export interface Props {
  teamA: string;
  teamB: string;
  teamAStats: DetailedTeamStats;
  teamBStats: DetailedTeamStats;
}

const { teamA, teamB, teamAStats, teamBStats } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const labels = [
  { key: 'atk', name: t('dim.atk') },
  { key: 'def', name: t('dim.def') },
  { key: 'pos', name: t('dim.pos') },
  { key: 'dis', name: t('dim.dis') },
  { key: 'frm', name: t('dim.frm') }
] as const;

const trendLabels = {
  up:   lang === 'zh-tw' ? '上升' : 'Rising',
  down: lang === 'zh-tw' ? '下降' : 'Falling',
  flat: lang === 'zh-tw' ? '持平' : 'Stable',
};

function getTrendHTML(trend: string) {
  if (trend.includes('+')) {
    return `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-400 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-label="${trendLabels.up}">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
            </svg>`;
  }
  if (trend.includes('-')) {
    return `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-label="${trendLabels.down}">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>`;
  }
  return `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-label="${trendLabels.flat}">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
          </svg>`;
}
---

<details class="w-full bg-slate-900 border border-slate-800 rounded-lg overflow-hidden group">
  <summary class="cursor-pointer p-4 flex justify-between items-center bg-slate-800/50 hover:bg-slate-800 transition-colors duration-200 font-bold text-sm text-amber-300 tracking-wide">
    <span>{t('stats.title')}</span>
    <svg class="w-4 h-4 text-slate-500 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </summary>

  <div class="p-0 border-t border-slate-800 max-h-[400px] overflow-y-auto">
    <table class="w-full text-left border-collapse">
      <thead class="bg-slate-950 text-slate-400 text-xs uppercase tracking-wider sticky top-0">
        <tr>
          <th class="p-3 w-1/4">{t('stats.dim')}</th>
          <th class="p-3 w-1/12 text-center">{t('stats.trend')}</th>
          <th class="p-3 w-2/3">{t('stats.reason')}</th>
        </tr>
      </thead>
      <tbody class="text-sm divide-y divide-slate-800/50">
        <!-- Team A -->
        <tr>
          <td colspan="3" class="bg-amber-400/10 text-amber-200 font-bold p-2 text-center tracking-wide">{teamA}</td>
        </tr>
        {labels.map(l => (
          <tr class="hover:bg-slate-800/30 transition-colors duration-200">
            <td class="p-3 font-mono font-bold text-slate-200">
              {l.name}
              <span class="block text-amber-200 text-lg">{teamAStats[l.key].score}</span>
            </td>
            <td class="p-3 text-center" set:html={getTrendHTML(teamAStats[l.key].trend)}></td>
            <td class="p-3 text-slate-300 leading-relaxed text-xs">
              {lang === 'zh-tw' ? teamAStats[l.key].reason_zh : teamAStats[l.key].reason_en}
            </td>
          </tr>
        ))}

        <!-- Team B -->
        <tr>
          <td colspan="3" class="bg-cyan-500/10 text-cyan-300 font-bold p-2 text-center tracking-wide">{teamB}</td>
        </tr>
        {labels.map(l => (
          <tr class="hover:bg-slate-800/30 transition-colors duration-200">
            <td class="p-3 font-mono font-bold text-slate-200">
              {l.name}
              <span class="block text-cyan-300 text-lg">{teamBStats[l.key].score}</span>
            </td>
            <td class="p-3 text-center" set:html={getTrendHTML(teamBStats[l.key].trend)}></td>
            <td class="p-3 text-slate-300 leading-relaxed text-xs">
              {lang === 'zh-tw' ? teamBStats[l.key].reason_zh : teamBStats[l.key].reason_en}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</details>
