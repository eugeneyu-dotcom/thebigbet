---
import { type DetailedTeamStats } from '../utils/calculateStats';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

export interface Props {
  teamA: string;
  teamB: string;
  teamAStats: DetailedTeamStats;
  teamBStats: DetailedTeamStats;
}

const { teamA, teamB, teamAStats, teamBStats } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const chartId = `radar-${Math.random().toString(36).slice(2, 8)}`;
const radarDataA = JSON.stringify([teamAStats.atk.score, teamAStats.def.score, teamAStats.pos.score, teamAStats.dis.score, teamAStats.frm.score]);
const radarDataB = JSON.stringify([teamBStats.atk.score, teamBStats.def.score, teamBStats.pos.score, teamBStats.dis.score, teamBStats.frm.score]);
const radarLabels = JSON.stringify([t('dim.atk'), t('dim.def'), t('dim.pos'), t('dim.dis'), t('dim.frm')]);

const labels = [
  { key: 'atk', name: t('dim.atk') },
  { key: 'def', name: t('dim.def') },
  { key: 'pos', name: t('dim.pos') },
  { key: 'dis', name: t('dim.dis') },
  { key: 'frm', name: t('dim.frm') }
] as const;

function getTrendIcon(trend: string): string {
  if (trend.includes('+')) return `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>`;
  if (trend.includes('-')) return `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>`;
  return `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" /></svg>`;
}

function getReason(stat: any): string {
  if (lang === 'zh-tw') return stat.reason_zh;
  if (lang === 'th' && stat.reason_th) return stat.reason_th;
  return stat.reason_en;
}
---

<details class="w-full bg-slate-900 border border-slate-800 rounded-lg overflow-hidden group">
  <summary class="cursor-pointer p-4 flex justify-between items-center bg-slate-800/50 hover:bg-slate-800 transition-colors duration-200 font-bold text-sm text-amber-300 tracking-wide">
    <span>{t('stats.title')}</span>
    <svg class="w-4 h-4 text-slate-500 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </summary>

  <div class="border-t border-slate-800 divide-y divide-slate-800/40">

    <!-- Radar chart — canvas is lazy-initialized via toggle event in <script> -->
    <div class="px-3 pt-4 pb-2">
      <div class="relative w-full h-[220px] flex items-center justify-center bg-slate-900/50 rounded-lg border border-slate-800/50">
        <canvas
          id={chartId}
          class="stats-radar-canvas"
          data-teama={teamA}
          data-teamb={teamB}
          data-teamadata={radarDataA}
          data-teambdata={radarDataB}
          data-labels={radarLabels}
        ></canvas>
      </div>
    </div>

    <!-- Team name header -->
    <div class="grid grid-cols-[1fr_3.5rem_1fr] px-3 py-2.5 bg-slate-950/50">
      <p class="text-amber-300 font-black text-xs text-center truncate px-1">{teamA}</p>
      <p></p>
      <p class="text-cyan-300 font-black text-xs text-center truncate px-1">{teamB}</p>
    </div>

    <!-- Each dimension: score row + reason row -->
    {labels.map(l => (
      <div class="px-3 py-3">
        <!-- Score + trend (left / dim / right) -->
        <div class="grid grid-cols-[1fr_3.5rem_1fr] items-center">
          <!-- Team A: trend icon + score, right-aligned -->
          <div class="flex items-center justify-end gap-1.5 pr-1">
            <span set:html={getTrendIcon(teamAStats[l.key].trend)}></span>
            <span class="text-2xl font-mono font-black text-amber-200 leading-none tabular-nums">{teamAStats[l.key].score}</span>
          </div>
          <!-- Dimension label -->
          <div class="text-center">
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{l.name}</span>
          </div>
          <!-- Team B: score + trend icon, left-aligned -->
          <div class="flex items-center justify-start gap-1.5 pl-1">
            <span class="text-2xl font-mono font-black text-cyan-300 leading-none tabular-nums">{teamBStats[l.key].score}</span>
            <span set:html={getTrendIcon(teamBStats[l.key].trend)}></span>
          </div>
        </div>

        <!-- Reason texts: two columns, readable size -->
        <div class="grid grid-cols-2 gap-3 mt-2">
          <p class="text-xs text-slate-400 leading-relaxed">{getReason(teamAStats[l.key])}</p>
          <p class="text-xs text-slate-400 leading-relaxed">{getReason(teamBStats[l.key])}</p>
        </div>
      </div>
    ))}
  </div>
</details>

<script>
  import Chart from 'chart.js/auto';

  function initRadarChart(canvas: HTMLCanvasElement) {
    if ((canvas as any)._radarInit) return;
    (canvas as any)._radarInit = true;

    const teamA = canvas.dataset.teama ?? '';
    const teamB = canvas.dataset.teamb ?? '';
    const teamAData: number[] = JSON.parse(canvas.dataset.teamadata ?? '[0,0,0,0,0]');
    const teamBData: number[] = JSON.parse(canvas.dataset.teambdata ?? '[0,0,0,0,0]');
    const dimLabels: string[] = JSON.parse(canvas.dataset.labels ?? '[]');

    new Chart(canvas, {
      type: 'radar',
      data: {
        labels: dimLabels,
        datasets: [
          {
            label: teamA,
            data: teamAData,
            backgroundColor: 'rgba(253, 230, 138, 0.25)',
            borderColor: 'rgb(253, 230, 138)',
            pointBackgroundColor: 'rgb(253, 230, 138)',
            pointBorderColor: '#0f172a',
            pointHoverBackgroundColor: '#0f172a',
            pointHoverBorderColor: 'rgb(253, 230, 138)',
            borderWidth: 2,
          },
          {
            label: teamB,
            data: teamBData,
            backgroundColor: 'rgba(34, 211, 238, 0.2)',
            borderColor: 'rgb(34, 211, 238)',
            pointBackgroundColor: 'rgb(34, 211, 238)',
            pointBorderColor: '#0f172a',
            pointHoverBackgroundColor: '#0f172a',
            pointHoverBorderColor: 'rgb(34, 211, 238)',
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              color: '#cbd5e1',
              font: { family: 'monospace', weight: 'bold', size: 13 },
              padding: 20,
            },
          },
        },
        scales: {
          r: {
            angleLines: { color: '#334155' },
            grid: { color: '#334155' },
            pointLabels: {
              color: '#f1f5f9',
              font: { family: 'monospace', size: 12, weight: 'bold' },
            },
            ticks: { display: false, min: 0, max: 10 },
          },
        },
      },
    });
  }

  // Lazy-init: wait for the enclosing <details> to open before rendering,
  // so chart.js sees a non-zero canvas height.
  document.querySelectorAll<HTMLCanvasElement>('.stats-radar-canvas').forEach(canvas => {
    const details = canvas.closest('details');
    if (!details || details.open) {
      initRadarChart(canvas);
    } else {
      details.addEventListener('toggle', () => {
        if (details.open) initRadarChart(canvas);
      });
    }
  });
</script>
