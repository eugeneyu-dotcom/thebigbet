---
export interface Props {
  teamA: string;
  teamB: string;
  results: number[]; // [wins, draws, losses]
}

const { teamA, teamB, results } = Astro.props;
const chartId = `h2h-chart-${Math.random().toString(36).substring(7)}`;
---

<h2h-chart>
  <div class="w-full max-w-2xl mx-auto p-4 bg-slate-900 rounded-xl border border-slate-800 my-6">
    <h3 class="text-base font-bold text-center mb-4 text-slate-200">歷史交鋒紀錄 (H2H)</h3>
    <div class="relative w-full h-[200px]">
      <canvas id={chartId} data-teama={teamA} data-teamb={teamB} data-results={JSON.stringify(results)}></canvas>
    </div>
  </div>
</h2h-chart>

<script>
  import Chart from 'chart.js/auto';

  class H2HChart extends HTMLElement {
    constructor() {
      super();
      const canvas = this.querySelector('canvas');
      if (!canvas) return;

      const teamA = canvas.dataset.teama;
      const teamB = canvas.dataset.teamb;
      const results = JSON.parse(canvas.dataset.results || '[0,0,0]');

      new Chart(canvas, {
        type: 'bar',
        data: {
          labels: ['勝', '平', '負'],
          datasets: [{
            label: `${teamA} 對陣 ${teamB} 戰績`,
            data: results,
            backgroundColor: [
              'rgba(74, 222, 128, 0.5)',
              'rgba(148, 163, 184, 0.4)',
              'rgba(248, 113, 113, 0.5)'
            ],
            borderColor: [
              'rgb(74, 222, 128)',
              'rgb(148, 163, 184)',
              'rgb(248, 113, 113)'
            ],
            borderWidth: 1
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false }
          },
          scales: {
            x: {
              beginAtZero: true,
              ticks: {
                stepSize: 1,
                color: '#94a3b8' // slate-400
              },
              grid: {
                color: '#1e293b' // slate-800
              }
            },
            y: {
              ticks: {
                color: '#cbd5e1' // slate-300
              },
              grid: {
                color: '#1e293b'
              }
            }
          }
        }
      });
    }
  }

  customElements.define('h2h-chart', H2HChart);
</script>
