---
export interface Props {
  teamA: string;
  teamB: string;
  results: number[]; // [teamA wins, draws, teamB wins]
  lang?: string;
}

const { teamA, teamB, results, lang = 'en' } = Astro.props;
const [aWins, draws, bWins] = results;
const total = aWins + draws + bWins;

const aPercent = total > 0 ? (aWins / total) * 100 : 0;
const dPercent = total > 0 ? (draws / total) * 100 : 0;
const bPercent = total > 0 ? 100 - aPercent - dPercent : 0;

const isZh = lang === 'zh-tw';
const title        = isZh ? '歷史交鋒紀錄' : 'Head-to-Head Record';
const homeWinsLabel = isZh ? '主隊勝' : 'Home Wins';
const drawsLabel    = isZh ? '平局'   : 'Draws';
const awayWinsLabel = isZh ? '客隊勝' : 'Away Wins';
const matchesLabel  = isZh ? `共 ${total} 場交鋒紀錄` : `${total} matches all-time`;
---

<div class="w-full p-5 rounded-xl border border-slate-700/60 bg-slate-900/60 mb-6">
  <p class="text-xs font-black text-slate-500 uppercase tracking-widest text-center mb-5">{title}</p>

  <!-- Three metric boxes -->
  <div class="grid grid-cols-3 gap-3 mb-4">
    <div class="text-center bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4">
      <p class="text-xs text-slate-400 mb-2 truncate font-bold">{teamA}</p>
      <p class="text-4xl font-black text-emerald-400 leading-none">{aWins}</p>
      <p class="text-xs text-slate-500 mt-2">{homeWinsLabel}</p>
    </div>
    <div class="text-center bg-slate-700/20 border border-slate-700/50 rounded-xl p-4">
      <p class="text-xs text-slate-500 mb-2 font-bold">—</p>
      <p class="text-4xl font-black text-slate-300 leading-none">{draws}</p>
      <p class="text-xs text-slate-500 mt-2">{drawsLabel}</p>
    </div>
    <div class="text-center bg-rose-500/10 border border-rose-500/20 rounded-xl p-4">
      <p class="text-xs text-slate-400 mb-2 truncate font-bold">{teamB}</p>
      <p class="text-4xl font-black text-rose-400 leading-none">{bWins}</p>
      <p class="text-xs text-slate-500 mt-2">{awayWinsLabel}</p>
    </div>
  </div>

  <!-- Proportional bar -->
  {total > 0 && (
    <div class="flex h-1.5 rounded-full overflow-hidden bg-slate-800">
      <div class="bg-emerald-500" style={`width: ${aPercent}%`}></div>
      <div class="bg-slate-600" style={`width: ${dPercent}%`}></div>
      <div class="bg-rose-500" style={`width: ${bPercent}%`}></div>
    </div>
  )}

  <p class="text-xs text-slate-600 text-center mt-3">{matchesLabel}</p>
</div>
