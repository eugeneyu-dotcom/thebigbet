---
import Header from './Header.astro';
import Footer from './Footer.astro';
import BaseHead from './BaseHead.astro';
import GoogleAnalytics from './GoogleAnalytics.astro';
import { useTeamTranslations } from '../i18n/ui';

interface Props {
  lang: string;
  entries: any[];
  basePath: string;      // article link prefix, e.g. /zh-tw/nba/analysis
  metaTitle: string;
  metaDescription: string;
  tag: string;
  heading: string;
  intro: string;
  emptyText: string;
}

const { lang, entries, basePath, metaTitle, metaDescription, tag, heading, intro, emptyText } = Astro.props;
const tTeam = useTeamTranslations(lang as any);
const isZhTw = lang === 'zh-tw';
const isTh = lang === 'th';

const sorted = [...entries].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<html lang={lang}>
  <head>
    <BaseHead title={metaTitle} description={metaDescription} lang={lang} />
    <GoogleAnalytics />
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex flex-col">
    <Header />
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow">

      <div class="mb-10">
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">{tag}</p>
        <h1 class="text-3xl font-black text-white">{heading}</h1>
        <p class="text-slate-400 mt-2 text-sm leading-relaxed">{intro}</p>
      </div>

      {sorted.length === 0 ? (
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-12 text-center">
          <p class="text-slate-500 text-sm">{emptyText}</p>
        </div>
      ) : (
        <ul class="space-y-4">
          {sorted.map((entry) => {
            const [, ...slugParts] = entry.id.split('/');
            const slug = slugParts.join('/');
            const matchParts = entry.data.match.split(' vs ');
            const teamA = tTeam(matchParts[0]?.trim() || '');
            const teamB = tTeam(matchParts[1]?.trim() || '');

            return (
              <li>
                <a
                  href={`${basePath}/${slug}`}
                  class="group block bg-slate-900 border border-slate-800 hover:border-amber-400/40 rounded-2xl p-6 transition-all duration-200"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-grow min-w-0">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-black bg-amber-400 text-slate-950 uppercase shrink-0">
                          {isZhTw ? `信心 ${entry.data.confidence}/5` : `${entry.data.confidence}/5`}
                        </span>
                        <time class="text-xs text-slate-500 font-mono" datetime={entry.data.pubDate.toISOString()}>
                          {entry.data.pubDate.toLocaleDateString(lang === 'zh-tw' ? 'zh-TW' : lang === 'th' ? 'th-TH' : 'en-US')}
                        </time>
                      </div>
                      <h2 class="text-lg font-bold text-white group-hover:text-amber-300 transition-colors duration-200 truncate">
                        {entry.data.title}
                      </h2>
                      <p class="text-sm text-slate-400 mt-1">
                        {teamA} <span class="text-slate-600">vs</span> {teamB}
                      </p>
                      {entry.data.prediction && (
                        <p class="text-sm font-bold text-amber-400 mt-2">
                          {isZhTw ? '預測：' : isTh ? 'ทำนาย: ' : 'Prediction: '}{entry.data.prediction}
                        </p>
                      )}
                    </div>
                    <svg class="w-5 h-5 text-slate-600 group-hover:text-amber-400 shrink-0 mt-1 transition-colors duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </main>
    <Footer />
  </body>
</html>
