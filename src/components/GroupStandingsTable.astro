---
import { useTeamTranslations, useTranslations } from '../i18n/ui';

interface Props {
  groupData: { group: string; teams: any[] };
  lang: string;
}

const { groupData, lang } = Astro.props;
const t = useTranslations(lang as any);
const tTeam = useTeamTranslations(lang as any);
---

<div class="overflow-x-auto bg-slate-800/60 border border-slate-700/80 rounded-xl shadow-lg">
  <table class="w-full text-left text-base whitespace-nowrap">
    <thead class="bg-slate-900/80 text-slate-300 font-bold uppercase tracking-wider text-sm border-b border-slate-700/50">
      <tr>
        <th class="p-4 rounded-tl-xl w-8">#</th>
        <th class="p-4 w-1/3">Team</th>
        <th class="p-4 text-center">MP</th>
        <th class="p-4 text-center">W</th>
        <th class="p-4 text-center">D</th>
        <th class="p-4 text-center">L</th>
        <th class="p-4 text-center">GF</th>
        <th class="p-4 text-center">GA</th>
        <th class="p-4 text-center">GD</th>
        <th class="p-4 text-center text-amber-300 rounded-tr-xl">Pts</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-700/50">
      {[...groupData.teams].sort((a, b) => b.pts - a.pts || b.gd - a.gd).map((team: any, idx) => {
        let rowClass = "hover:bg-slate-700/40 transition-colors duration-150 ";
        if (team.status === "qualified") rowClass += "bg-green-600/25";
        else if (team.status === "eliminated") rowClass += "bg-red-600/20";

        return (
          <tr class={rowClass}>
            <td class="p-4 font-mono font-bold text-slate-400">{idx + 1}</td>
            <td class="p-4 font-bold text-white text-lg">
              <span class="flex items-center gap-2">
                {tTeam(team.name)}
                {team.status === 'qualified' && (
                  <span class="text-xs bg-green-500 text-white px-1.5 py-0.5 rounded font-black border border-green-300 shadow-sm" title={t('status.qualified')}>&#10003;</span>
                )}
                {team.status === 'eliminated' && (
                  <span class="text-xs bg-red-500 text-white px-1.5 py-0.5 rounded font-black border border-red-300 shadow-sm" title={t('status.eliminated')}>&#215;</span>
                )}
              </span>
            </td>
            <td class="p-4 text-center font-mono text-slate-200">{team.mp}</td>
            <td class="p-4 text-center font-mono text-slate-200">{team.w}</td>
            <td class="p-4 text-center font-mono text-slate-200">{team.d}</td>
            <td class="p-4 text-center font-mono text-slate-200">{team.l}</td>
            <td class="p-4 text-center font-mono text-slate-300">{team.gf}</td>
            <td class="p-4 text-center font-mono text-slate-300">{team.ga}</td>
            <td class="p-4 text-center font-mono font-bold text-slate-200">{team.gd > 0 ? `+${team.gd}` : team.gd}</td>
            <td class="p-4 text-center font-mono font-black text-amber-300 text-xl">{team.pts}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
<div class="mt-3 flex gap-4 text-sm font-bold px-2">
  <div class="flex items-center gap-1.5 text-green-400 font-black">
    <div class="w-3 h-3 rounded-sm bg-green-500 border border-green-300"></div>
    <span>&#10003; {t('status.qualified')}</span>
  </div>
  <div class="flex items-center gap-1.5 text-red-400 font-black">
    <div class="w-3 h-3 rounded-sm bg-red-500 border border-red-300"></div>
    <span>&#215; {t('status.eliminated')}</span>
  </div>
</div>
